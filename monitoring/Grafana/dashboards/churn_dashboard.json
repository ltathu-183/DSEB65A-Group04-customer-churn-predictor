{
  "title": "Churn Prediction Monitoring",
  "uid": "churn-monitoring",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mlops", "churn"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API Status (Up)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "up{job=\"ml-api\"}" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(http_request_duration_seconds_count[5m]))" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Model Predictions Total",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "model_predictions_total" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p95 (5m)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Confidence Mean",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "confidence_mean" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Feature Drift Count",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "refId": "A", "expr": "feature_drift_count" }]
    }
  ]
}
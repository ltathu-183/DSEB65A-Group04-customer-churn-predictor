# =====================
# Python & Environment
# =====================
__pycache__/
*.py[cod]
.env
.venv/
venv/
*.egg-info/

# =====================
# Logs & Monitoring Config (SỬA LỖI Ở ĐÂY)
# =====================
logs/
*.log
# Chỉ ignore các file json rác, GIỮ LẠI file cấu hình quan trọng
*.json
!monitoring/**/*.json
!config/**/*.json
!models/*.json

# =====================
# ML artifacts & Models
# =====================
models/run_*
mlruns/
mlflow.db
# Giữ lại các file code train model
!models/*.py

# =====================
# Data & DVC (QUAN TRỌNG NHẤT)
# =====================
# Ignore dữ liệu nặng nhưng phải GIỮ LẠI file .dvc để nhóm pull được data
data/raw/*
data/processed/*
!data/**/*.dvc

# Các định dạng file data nặng
*.csv
*.parquet
*.pkl
*.h5

# =====================
# Infrastructure & IDE
# =====================
.ipynb_checkpoints/
.vscode/
.idea/
*.db
!prometheus.yml